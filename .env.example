# OmniWall environment config — copy to .env and edit

# Server port (host-side)
PORT=3001

# Anthropic API key — required for Claude AI agent in voice mode
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Weather — find your lat/lon at open-meteo.com
WEATHER_LAT=51.5074
WEATHER_LON=-0.1278
WEATHER_CITY=London

# Uncomment for CEC/audio passthrough (RPi)
# UID=1000
# DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus
